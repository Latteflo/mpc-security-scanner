# Generated reports — keep the directory structure, ignore outputs.
# SARIF files may contain sensitive scan data and are large; upload them
# as CI artifacts or to the GitHub Security tab instead of committing them.
reports/scans/
reports/compliance/
reports/*.json
reports/*.html
reports/*.pdf
reports/*.md
reports/*.sarif
!reports/.gitkeep
!reports/demos/
!reports/demos/.gitkeep
!reports/demos/*.json
!reports/demos/*.html
!reports/demos/*.md

# Baseline files produced by --save-baseline (may contain internal host info)
*.baseline.json
baselines/

# Logs
*.log
logs/

# Claude Code configuration — personal, not for the repo
CLAUDE.md

# Secrets / environment
.env
.env.local
.env.*.local
config/secrets.yaml
config/production.yaml

